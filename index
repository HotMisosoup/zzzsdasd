<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>THE EVERYTHING COMPANY — $EVERYTHING</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Bebas+Neue&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #000000;
    --white: #ffffff;
    --gold: #c8a84b;
    --gold-bright: #f5d06b;
    --gold-dim: #7a6328;
    --cyan: #00ffe7;
    --cyan-dim: #004d45;
    --red: #ff3b3b;
    --grey: #888;
    --dark: #0a0a0a;
    --panel: #0e0e0e;
    --twitter: #1d9bf0;
    --twitter-dim: #0a3d5e;
    --twitter-glow: rgba(29,155,240,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Rajdhani', sans-serif;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* SCANLINE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* NOISE TEXTURE */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9998;
    opacity: 0.3;
  }

  /* ─── HERO ─── */
  #hero {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid var(--gold-dim);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,168,75,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,168,75,0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridShift 20s linear infinite;
  }

  @keyframes gridShift {
    0% { transform: perspective(600px) rotateX(20deg) translateY(0); }
    100% { transform: perspective(600px) rotateX(20deg) translateY(60px); }
  }

  .radial-glow {
    position: absolute;
    width: 900px; height: 900px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,168,75,0.08) 0%, transparent 70%);
    animation: pulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  .hero-ticker {
    position: absolute;
    top: 0;
    width: 100%;
    background: var(--gold);
    color: var(--black);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 0;
    overflow: hidden;
    white-space: nowrap;
    z-index: 10;
  }

  .ticker-inner {
    display: inline-block;
    animation: ticker 25s linear infinite;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .x-logo-big {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(200px, 35vw, 500px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(29,155,240,0.2);
    position: absolute;
    letter-spacing: -10px;
    user-select: none;
    z-index: 0;
  }

  @keyframes xpulse {
    0%, 100% { -webkit-text-stroke: 1px rgba(29,155,240,0.12); }
    50% { -webkit-text-stroke: 1px rgba(29,155,240,0.35); text-shadow: 0 0 120px rgba(29,155,240,0.08); }
  }

  @keyframes glitch {
    0%, 60%, 100% { text-shadow: none; transform: none; }
    61% { text-shadow: 3px 0 var(--cyan), -3px 0 var(--red); transform: skewX(2deg); }
    63% { text-shadow: -3px 0 var(--cyan), 3px 0 var(--red); transform: skewX(-2deg); }
    65% { text-shadow: none; transform: none; }
    67% { text-shadow: 2px 0 var(--gold); transform: skewX(1deg); }
    69% { text-shadow: none; transform: none; }
  }

  .x-logo-big { animation: xpulse 2s ease-in-out infinite, glitch 1.5s infinite; }

  .hero-content {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 0 20px;
  }

  .hero-eyebrow {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 1s 0.3s forwards;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 10vw, 140px);
    line-height: 0.9;
    letter-spacing: 4px;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 1s 0.5s forwards;
  }

  .hero-title span {
    display: block;
    color: var(--gold);
    text-shadow: 0 0 40px rgba(200,168,75,0.4), 0 0 80px rgba(200,168,75,0.15);
  }

  .hero-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.7;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 1s 0.7s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 1s 0.9s forwards;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--black);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    padding: 14px 40px;
    border: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s;
  }

  .btn-primary:hover::before { left: 100%; }
  .btn-primary:hover { box-shadow: 0 0 30px rgba(200,168,75,0.5); transform: translateY(-2px); }

  .btn-outline {
    background: transparent;
    color: var(--gold);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    padding: 13px 40px;
    border: 1px solid var(--gold-dim);
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
  }

  .btn-outline:hover {
    border-color: var(--gold);
    background: rgba(200,168,75,0.08);
    box-shadow: 0 0 20px rgba(200,168,75,0.15);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── STATS BAR ─── */
  .stats-bar {
    background: var(--panel);
    border-top: 1px solid var(--twitter-dim);
    border-bottom: 1px solid var(--twitter-dim);
    display: flex;
    justify-content: center;
    gap: 0;
    overflow: hidden;
  }

  .stat-item {
    flex: 1;
    max-width: 340px;
    padding: 28px 40px;
    text-align: center;
    border-right: 1px solid rgba(29,155,240,0.12);
    position: relative;
    transition: background 0.3s;
  }

  .stat-item:hover { background: rgba(29,155,240,0.04); }
  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    color: var(--twitter);
    letter-spacing: 2px;
    display: block;
    text-shadow: 0 0 20px var(--twitter-glow);
  }

  .stat-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--grey);
    text-transform: uppercase;
  }

  /* ─── TWEETS SECTION ─── */
  .section {
    padding: 100px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 6px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--gold-dim), transparent);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: 60px;
  }

  .section-title em {
    color: var(--gold);
    font-style: normal;
  }

  /* TWEET CARDS */
  .tweets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
    margin-bottom: 60px;
  }

  .tweet-card {
    background: var(--panel);
    border: 1px solid rgba(200,168,75,0.12);
    padding: 24px;
    position: relative;
    transition: all 0.4s;
    overflow: hidden;
  }

  .tweet-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--gold);
    transition: height 0.4s;
  }

  .tweet-card:hover {
    border-color: rgba(200,168,75,0.35);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px rgba(200,168,75,0.06);
  }

  .tweet-card:hover::before { height: 100%; }

  .tweet-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .tweet-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border: 2px solid var(--gold-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--gold);
    flex-shrink: 0;
  }

  .tweet-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .verified { color: #1d9bf0; font-size: 14px; }
  .x-badge {
    background: var(--white);
    color: var(--black);
    font-size: 9px;
    font-weight: 900;
    padding: 1px 4px;
    border-radius: 2px;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 1px;
  }

  .tweet-handle {
    font-size: 12px;
    color: var(--grey);
    font-family: 'Share Tech Mono', monospace;
  }

  .subscribe-btn {
    margin-left: auto;
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .subscribe-btn:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }

  .tweet-body {
    font-size: 17px;
    line-height: 1.6;
    font-weight: 400;
    color: rgba(255,255,255,0.92);
    margin-bottom: 16px;
  }

  .tweet-body .highlight {
    color: var(--gold);
    font-weight: 600;
  }

  .tweet-meta {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--grey);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 12px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .tweet-views { margin-left: auto; display: flex; align-items: center; gap: 4px; }

  /* FEATURED TWEET (big) */
  .tweet-featured {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, rgba(200,168,75,0.06), rgba(0,0,0,0));
    border-color: rgba(200,168,75,0.25);
  }

  .tweet-featured .tweet-body {
    font-size: 22px;
    font-weight: 500;
  }

  /* ─── NARRATIVE SECTION ─── */
  .narrative-wrapper {
    background: var(--panel);
    border: 1px solid rgba(200,168,75,0.12);
    padding: 60px;
    position: relative;
    overflow: hidden;
  }

  .narrative-wrapper::before {
    content: '"';
    position: absolute;
    top: -20px; left: 40px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 200px;
    color: rgba(200,168,75,0.05);
    line-height: 1;
    pointer-events: none;
  }

  .narrative-text {
    font-size: 20px;
    line-height: 1.9;
    color: rgba(255,255,255,0.75);
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .narrative-text strong {
    color: var(--gold);
    font-weight: 700;
  }

  /* ─── FEATURES GRID ─── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
    background: rgba(200,168,75,0.08);
    border: 1px solid rgba(200,168,75,0.12);
  }

  .feature-card {
    background: var(--black);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .feature-card:hover { background: rgba(200,168,75,0.03); }

  .feature-icon {
    font-size: 32px;
    margin-bottom: 20px;
    display: block;
    filter: grayscale(0.3);
  }

  .feature-num {
    position: absolute;
    top: 16px; right: 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 60px;
    color: rgba(200,168,75,0.05);
    line-height: 1;
    pointer-events: none;
  }

  .feature-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    letter-spacing: 2px;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .feature-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ─── TERMINAL ─── */
  .terminal-wrapper {
    background: #050505;
    border: 1px solid rgba(0,255,231,0.2);
    padding: 0;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(0,255,231,0.05);
    position: relative;
  }

  .terminal-bar {
    background: #111;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(0,255,231,0.1);
  }

  .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  .t-dot.red { background: #ff5f57; }
  .t-dot.yellow { background: #febc2e; }
  .t-dot.green { background: #28c840; }

  .terminal-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: rgba(0,255,231,0.5);
    margin-left: 8px;
    flex: 1;
  }

  .terminal-status {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: #28c840;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .t-live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #28c840;
    animation: blink 1s infinite;
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .terminal-body {
    padding: 20px 24px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: rgba(0,255,231,0.7);
    height: 380px;
    overflow-y: auto;
    line-height: 1.8;
  }

  .terminal-body::-webkit-scrollbar { width: 4px; }
  .terminal-body::-webkit-scrollbar-thumb { background: rgba(0,255,231,0.2); }

  .t-line { display: block; animation: fadeIn 0.3s forwards; }
  .t-prompt { color: var(--gold); }
  .t-success { color: #28c840; }
  .t-warning { color: #febc2e; }
  .t-error { color: var(--red); }
  .t-dim { color: rgba(0,255,231,0.3); }
  .t-bright { color: var(--cyan); }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .cursor-blink {
    display: inline-block;
    width: 8px; height: 14px;
    background: var(--cyan);
    animation: blink 0.8s infinite;
    vertical-align: middle;
    margin-left: 2px;
  }

  /* ─── TOKENOMICS ─── */
  .tokenomics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .tokenomics-grid { grid-template-columns: 1fr; }
    .tweets-grid { grid-template-columns: 1fr; }
    .section { padding: 60px 20px; }
    .narrative-wrapper { padding: 30px; }
    .stats-bar { flex-wrap: wrap; }
    .stat-item { min-width: 45%; }
  }

  .toke-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .toke-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: var(--panel);
    border: 1px solid rgba(200,168,75,0.08);
    transition: all 0.3s;
  }

  .toke-row:hover {
    border-color: rgba(200,168,75,0.25);
    background: rgba(200,168,75,0.04);
  }

  .toke-bar-wrap {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.05);
  }

  .toke-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--gold-dim), var(--gold));
    transition: width 1.5s ease;
  }

  .toke-label { font-size: 13px; color: rgba(255,255,255,0.6); min-width: 120px; font-weight: 300; }
  .toke-pct { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: var(--gold); min-width: 60px; }

  /* TWEET SCREENSHOT EMBED */
  .tweet-screenshot {
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 12px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .tweet-screenshot img {
    width: 100%;
    display: block;
    object-fit: cover;
    border-radius: 4px;
    filter: brightness(0.95);
    transition: filter 0.3s;
  }

  .tweet-card:hover .tweet-screenshot img { filter: brightness(1.05); }

  .tweet-overlay-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: 8px;
  }

  .tweet-link-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(29,155,240,0.7);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tweet-link {
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }

  .tweet-link:hover .tweet-link-label { color: var(--twitter); }
  .pie-chart-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .pie-svg { width: 260px; height: 260px; }

  .pie-legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.6);
  }

  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  /* ─── HARDLINE ─── */
  .hardline-wrapper {
    padding: 20px 0 0;
  }

  .hardline-inner {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .hardline-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  }

  .hardline-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(14px, 2.2vw, 22px);
    letter-spacing: 3px;
    color: rgba(255,255,255,0.35);
    text-align: center;
    flex: 3;
    line-height: 1.4;
  }

  /* ─── COMMUNITY SECTION ─── */
  .community-section {
    background: var(--panel);
    border-top: 1px solid rgba(200,168,75,0.12);
    border-bottom: 1px solid rgba(200,168,75,0.12);
  }

  .community-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .community-inner { grid-template-columns: 1fr; gap: 40px; }
    .tokenomics-grid { grid-template-columns: 1fr; }
  }

  .community-text h2 {
    font-family: 'Bebas Neue', sans-serif;
